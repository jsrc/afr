# 仅放敏感信息（会覆盖 config.ini 同名键）
# 推荐：
# - TELEGRAM_BOT_TOKEN 放这里
# - TELEGRAM_CHAT_ID 放 config.ini
# 只有在你确实需要覆盖目标频道时，才把 TELEGRAM_CHAT_ID 放到这里

# DeepL API Key（必填）
DEEPL_API_KEY=your_deepl_api_key

# Telegram bot token（可选，敏感）
TELEGRAM_BOT_TOKEN=

# 可选：仅在需要覆盖 config.ini 里的目标频道时再启用
# TELEGRAM_CHAT_ID=@your_channel

# 如需浏览器登录抓 AFR 付费内容，请先安装 browser 依赖：
# pip install -e '.[browser]'
# python -m playwright install chromium

# MiniApp API 最小鉴权 key（推荐放 .env）
MINIAPP_API_KEY=replace_with_a_long_random_secret
